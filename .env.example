# =====================================================
# WhatsApp AI Agent — Variáveis de Ambiente
# =====================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com valores reais!
# =====================================================

# ── Supabase ──────────────────────────────────────────
# Disponíveis automaticamente nas Edge Functions,
# mas necessárias para desenvolvimento local.
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── Google Gemini ─────────────────────────────────────
GEMINI_API_KEY=sua_gemini_api_key_aqui

# ── Z-API ─────────────────────────────────────────────
ZAPI_INSTANCE_ID=seu_instance_id_aqui
ZAPI_TOKEN=seu_token_aqui
ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# ── Bot ───────────────────────────────────────────────
# System prompt que define o comportamento do agente.
# Pode ser um texto longo com instruções detalhadas.
BOT_SYSTEM_PROMPT=Você é um assistente útil e educado.
